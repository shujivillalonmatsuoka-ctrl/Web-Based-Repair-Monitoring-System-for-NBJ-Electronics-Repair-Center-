<!DOCTYPE html>
<html>
<head>
<title>Add Customer</title>

<style>
body {
    background: #1e1e1e;
    color: white;
    font-family: Arial;
}

.container {
    width: 400px;
    margin: 50px auto;
    background: #2a2a2a;
    padding: 30px;
    border-radius: 10px;
}

input {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
}

button {
    width: 100%;
    padding: 10px;
    background: red;
    color: white;
    border: none;
}
</style>

</head>

<body>

<div class="container">
<h2>Add Customer</h2>

<form action="addCustomer" method="post">
    <input type="text" name="username" placeholder="Username" required>
    <input type="password" name="password" placeholder="Password" required>
    <button type="submit">Create Account</button>
</form>

</div>

</body>
</html>
